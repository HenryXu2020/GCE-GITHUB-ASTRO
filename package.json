{
  "name": "astro-vitesse-site",
  "type": "module",
  "version": "1.5.0",
  "scripts": {
    "prepare": "simple-git-hooks",
    "codegen": "graphql-codegen --config codegen.config.js",
    "generate-dynamic": "tsx scripts/generate-queries-correct.ts",
    "codegen-dynamic": "graphql-codegen --config codegen-dynamic.config.js",
    "build-dynamic": "npm run analyze-schema && npm run generate-dynamic && npm run codegen-dynamic",
    "clean-generated": "rm -f src/generated/all-queries.graphql src/generated/graphql-types.ts src/generated/config.ts src/generated/content-types.ts src/generated/content-cache.*",
    "predev": "npm run clean-generated && npm run build-dynamic && npm run generate-config && npm run build-cache",
    "dev": "astro dev --host",
    "prebuild": "npm run clean-generated && npm run build-dynamic && npm run generate-config && npm run build-cache",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "bumpp",
    "generate-config": "tsx scripts/fetch-strapi-config.ts",
    "refresh-config": "tsx scripts/fetch-strapi-config.ts --force",
    "test-config": "tsx scripts/fetch-strapi-config.ts",
    "generate-types": "graphql-codegen --config codegen.config.js",
    "start": "astro dev --host",
    "check": "astro check",
    "sync": "astro sync",
    "analyze-schema": "tsx scripts/analyze-schema.ts",
    "generate-correct-queries": "tsx scripts/generate-queries-correct.ts",
    "validate-schema": "npm run analyze-schema && npm run generate-types-dynamic && npm run generate-config",
    "validate-dynamic": "npm run generate-dynamic && npm run codegen-dynamic && npm run generate-config && echo '✅ Dynamic architecture validated'",
    "validate-generated": "if [ -f src/generated/all-queries.graphql ] && [ -f src/generated/graphql-types.ts ]; then echo '✅ Generated files exist'; else echo '❌ Generated files missing'; exit 1; fi",
    "build-cache": "tsx scripts/build-content-cache.ts",
    "update-cache": "tsx scripts/update-cache.ts",
    "update-cache-entry": "tsx scripts/update-cache-entry.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.2.4",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/vue": "^5.0.10",
    "@unocss/reset": "66.1.0-beta.11",
    "astro": "^5.6.2",
    "express": "^5.2.1",
    "graphql": "^16.12.0",
    "graphql-request": "^7.4.0",
    "nprogress": "^0.2.0",
    "unocss": "66.1.0-beta.11",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.12.0",
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/typescript": "^5.0.3",
    "@graphql-codegen/typescript-graphql-request": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^5.0.3",
    "@iconify/json": "^2.2.327",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.0.0",
    "@types/nprogress": "^0.2.3",
    "@vueuse/core": "^13.1.0",
    "bumpp": "^10.1.0",
    "dotenv": "^16.0.0",
    "eslint": "^9.24.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-format": "^1.0.1",
    "lint-staged": "^15.5.1",
    "lodash-es": "^4.17.21",
    "prettier-plugin-astro": "^0.14.1",
    "simple-git-hooks": "^2.12.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "npm run lint:fix"
  }
}
