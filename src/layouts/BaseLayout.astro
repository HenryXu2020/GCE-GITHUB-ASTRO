---
// src/layouts/BaseLayout.astro
import { fade } from 'astro:transitions';
import { ViewTransitions } from 'astro:transitions';
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.vue';
import ScrollToTop from '@/components/ScrollToTop.vue';
import type { Locale, FooterData } from '@/types';
import { getSingleContent } from '@/lib/content-cache';
import { getSiteConfig } from '@/site-config';

interface Props {
  title?: string;
  description?: string;
  pageType?: 'article' | 'website';
  locale?: Locale;
  image?: { src: string; alt: string };
}

const { title, description, pageType = 'website', locale, image } = Astro.props;
const currentLocale = (Astro.currentLocale || locale || 'en') as Locale;
const config = getSiteConfig(currentLocale);
const cachedFooter = getSingleContent<FooterData>('footer', currentLocale);
const footerData = cachedFooter?.data ?? null;
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <BaseHead
      title={title || config.title}
      description={description || config.description}
      pageType={pageType}
      locale={currentLocale}
      url={Astro.url}
      image={image || config.image}
      config={config}
    />
    <ViewTransitions />
  </head>
  <body class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen font-sans antialiased transition-colors duration-300">
    <Header currentLocale={currentLocale} config={config} />
    <main class="min-h-screen pt-20 pb-16" transition:animate={fade({ duration: '0.4s' })}>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <slot />
      </div>
    </main>
    <!-- 将 currentLocale 传递给 Footer 组件，用于生成本地化链接 -->
    <Footer footer={footerData} currentLocale={currentLocale} client:load />
    <ScrollToTop client:load />
  </body>
</html>
