---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { locales, type Locale } from '@/generated/i18n-config';
import { getContentList } from '@/lib/content-cache';
import type { Blog } from '@/generated/graphql-types';
import { t } from '@/i18n/dict';
import { Image } from 'astro:assets';
import { getFullImageUrl, getLocalizedPath } from '@/lib/env';

export async function getStaticPaths() {
  return locales.map((locale) => ({
    params: { locale },
  }));
}

const { locale } = Astro.params as { locale: Locale };
const blogs = getContentList<Blog>('blog', locale);
---

<BaseLayout title={t(locale, 'blog.title')} locale={locale}>
  <div class="container mx-auto px-4 py-8">
    <header class="mb-12">
      <h1 class="text-5xl font-bold mb-4">{t(locale, 'blog.title')}</h1>
      <p class="text-xl text-gray-600 dark:text-gray-400">{t(locale, 'blog.subtitle')}</p>
    </header>

    {blogs.length === 0 ? (
      <div class="text-center py-12">
        <p class="text-xl text-gray-500 dark:text-gray-400">{t(locale, 'blog.noPosts')}</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {blogs.map((blog) => {
          // 处理 cover 数组：取第一个图片对象
          const coverItem = Array.isArray(blog.cover) ? blog.cover[0] : blog.cover;
          const coverImageUrl = getFullImageUrl(coverItem?.url);
          const coverAlt = coverItem?.alternativeText || blog.title;
          const blogUrl = getLocalizedPath(locale, `/blog/${blog.slug}`);
          return (
            <article key={blog.documentId} class="card bg-white dark:bg-gray-800 rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300">
              {coverImageUrl && (
                <a href={blogUrl}>
                  <Image src={coverImageUrl} alt={coverAlt} width={600} height={400} class="w-full h-48 object-cover" loading="lazy" decoding="async" format="webp" />
                </a>
              )}
              <div class="p-6">
                <h2 class="text-2xl font-bold mb-3">
                  <a href={blogUrl} class="hover:text-primary transition-colors">{blog.title}</a>
                </h2>
                <div class="text-sm text-gray-600 dark:text-gray-400 mb-4 flex items-center">
                  {blog.author && (
                    <>
                      <span class="font-medium">{blog.author}</span>
                      <span class="mx-2">•</span>
                    </>
                  )}
                  <time datetime={blog.publishedAt}>
                    {new Date(blog.publishedAt).toLocaleDateString(locale, {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </time>
                </div>
                {blog.excerpt && <p class="text-gray-700 dark:text-gray-300 mb-4 line-clamp-3">{blog.excerpt}</p>}
                <a href={blogUrl} class="inline-flex items-center text-primary hover:underline font-medium">
                  {t(locale, 'blog.readMore')}
                  <i class="i-carbon-arrow-right ml-2"></i>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>
