---
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { Locale } from '@/types';
import { locales } from '@/generated/i18n-config';
import { t } from '@/i18n/dict';

export async function getStaticPaths() {
  return locales.map((locale: Locale) => ({
    params: { locale },
  }));
}

const currentLocale = Astro.currentLocale as Locale;

// 所有文本均从 Strapi 翻译系统获取
const title = t(currentLocale, '404.title');
const description = t(currentLocale, '404.description');
const prompt = t(currentLocale, '404.prompt');
const returnHome = t(currentLocale, '404.returnHome');

// 导航链接文本（需在 Strapi translations 中定义）
const navLinks = {
  blog: t(currentLocale, 'nav.blog'),
  projects: t(currentLocale, 'nav.projects'),
  notes: t(currentLocale, 'nav.notes'),
};
---

<BaseLayout
  title={title}
  description={description}
  locale={currentLocale}
>
  <div class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4">
    <div class="mb-8">
      <div class="text-9xl font-bold text-gray-300 dark:text-gray-700 mb-2">404</div>
      <h1 class="text-3xl font-bold mb-4">{title}</h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-md mx-auto">
        {description}
      </p>
    </div>

    <div class="space-y-4">
      <a
        href={`/${currentLocale}`}
        class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition-colors"
      >
        {returnHome}
      </a>

      <div class="text-sm text-gray-500 dark:text-gray-400">
        <p class="mb-2">{prompt}</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href={`/${currentLocale}/blog`} class="text-blue-600 dark:text-blue-400 hover:underline">
            {navLinks.blog}
          </a>
          <a href={`/${currentLocale}/projects`} class="text-blue-600 dark:text-blue-400 hover:underline">
            {navLinks.projects}
          </a>
          <a href={`/${currentLocale}/notes`} class="text-blue-600 dark:text-blue-400 hover:underline">
            {navLinks.notes}
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
