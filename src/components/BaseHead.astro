---
import type { Locale } from '@/generated/i18n-config';
import { getLocalizedUrl } from '@/i18n/utils';
import { locales } from '@/generated/i18n-config';

interface Props {
  title: string;
  description: string;
  pageType?: 'article' | 'website';
  locale: Locale;
  url: URL;
  image?: { src: string; alt: string };
  config: {
    title: string;
    description: string;
    image: { src: string; alt: string };
    author: string;
    theme_color_light?: string;
    theme_color_dark?: string;
    twitter_card_type?: string;
    fb_app_id?: string;
    google_analytics_id?: string;
    umami_website_id?: string;
    rss_enabled?: boolean; // 添加 RSS 启用标志（由 site-config 提供）
  };
}

const { title, description, pageType = 'website', locale, url, image, config } = Astro.props;
const siteUrl = Astro.site?.origin || 'https://example.com';
const canonicalUrl = new URL(url.pathname, siteUrl).toString();
const fallbackImage = '/default-og.png'; // 静态后备图片，请确保 public 目录下存在该文件
const imageUrl = image?.src || config.image.src || fallbackImage;
const alternateUrls = locales.map((targetLocale: Locale) => {
  const localizedUrl = getLocalizedUrl(url, targetLocale);
  const fullUrl = new URL(localizedUrl, siteUrl).toString();
  return { lang: targetLocale, href: fullUrl };
});
// 使用 ?? 避免空字符串被错误替换
const themeColorLight = config.theme_color_light ?? '#ffffff';
const themeColorDark = config.theme_color_dark ?? '#0f172a';
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content="Astro v5.6.2" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content={config.author} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={pageType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={config.title} />
  <meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />

  {imageUrl && (
    <>
      <meta property="og:image" content={imageUrl} />
      <meta property="og:image:alt" content={image?.alt || config.image.alt} />
      <meta property="og:image:width" content="1200" />
      <meta property="og:image:height" content="630" />
    </>
  )}

  <meta name="twitter:card" content={config.twitter_card_type || 'summary_large_image'} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {imageUrl && <meta name="twitter:image" content={imageUrl} />}

  {config.fb_app_id && <meta property="fb:app_id" content={config.fb_app_id} />}

  {config.google_analytics_id && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${config.google_analytics_id}`}></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '${config.google_analytics_id}');
      </script>
    </>
  )}

  {config.umami_website_id && (
    <script async defer src="https://analytics.umami.is/script.js" data-website-id={config.umami_website_id}></script>
  )}

  {alternateUrls.map(({ lang, href }) => (
    <link rel="alternate" hreflang={lang} href={href} key={lang} />
  ))}
  <link rel="alternate" hreflang="x-default" href={alternateUrls.find(a => a.lang === 'en')?.href || canonicalUrl} />

  <link rel="canonical" href={canonicalUrl} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" href="/favicon.ico" type="image/x-icon" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />

  <!-- RSS 链接由 Header 组件根据 config.rss_enabled 条件渲染，此处不再放置 -->

  <meta name="theme-color" media="(prefers-color-scheme: light)" content={themeColorLight} />
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content={themeColorDark} />

  <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml" />
</head>
